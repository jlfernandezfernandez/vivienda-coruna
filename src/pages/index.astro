---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import OpportunityCard from '../components/OpportunityCard.astro';
import monitor from '../data/monitor.json';

const items = Array.isArray(monitor.items) ? monitor.items : [];
const sources = Array.isArray(monitor.sources) ? monitor.sources : [];
const healthySources = sources.filter((source) => source.ok).length;
const checkedAt = monitor.checkedAt ? new Date(monitor.checkedAt) : null;
const checkedLabel = checkedAt
  ? checkedAt.toLocaleString('es-ES', { dateStyle: 'long', timeStyle: 'short', timeZone: 'Europe/Madrid' })
  : 'Pendiente de la primera comprobación';
---

<Layout
  title="Vivienda Coruña — Vivienda protegida y cooperativa en A Coruña"
  description="Monitor de publicaciones oficiales y alertas locales sobre vivienda protegida, cooperativas y suelo en el área de A Coruña."
>
  <section class="intro shell" aria-labelledby="page-title">
    <div class="intro__copy">
      <p class="eyebrow">Vivienda protegida y cooperativa</p>
      <h1 id="page-title">Lo nuevo, cerca de casa.</h1>
      <p class="lede">Seguimos convocatorias oficiales, adjudicaciones, suelo público y alertas locales de cooperativas en el área de A Coruña.</p>
    </div>

    <aside class="scan-status" aria-label="Estado de la última comprobación">
      <div class={`status-dot ${healthySources === sources.length && sources.length > 0 ? 'status-dot--ok' : ''}`}></div>
      <div>
        <span>Última comprobación</span>
        <strong>{checkedLabel}</strong>
        {sources.length > 0 && <small>{healthySources} de {sources.length} fuentes disponibles</small>}
      </div>
    </aside>
  </section>

  <section class="results shell" aria-labelledby="results-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Publicaciones relevantes</p>
        <h2 id="results-title">{items.length === 0 ? 'Sin publicaciones recientes' : `${items.length} ${items.length === 1 ? 'publicación' : 'publicaciones'}`}</h2>
      </div>
      {items.length > 0 && <p>Ordenadas por fecha de publicación</p>}
    </div>

    {items.length === 0 ? (
      <div class="empty-state">
        <div class="empty-state__signal" aria-hidden="true"><span></span></div>
        <div class="empty-state__copy">
          <h3>Ahora mismo no hay nada que revisar.</h3>
          <p>Las fuentes oficiales no muestran publicaciones relevantes para el área seleccionada. Volveremos a comprobarlas automáticamente.</p>
        </div>
      </div>
    ) : (
      <div class="opportunity-list">
        {items.map((item) => <OpportunityCard {...item} />)}
      </div>
    )}
  </section>

  <section class="coverage shell" aria-labelledby="coverage-title">
    <div class="coverage__intro">
      <p class="eyebrow">Cobertura exacta</p>
      <h2 id="coverage-title">Solo el área de A Coruña.</h2>
      <p>Incluye los nueve municipios del área funcional; Ferrol, Santiago y el resto de la provincia quedan fuera.</p>
    </div>
    <ul class="place-list" aria-label="Localidades incluidas">
      {monitor.area.map((place) => <li>{place}</li>)}
    </ul>
  </section>

  {sources.length > 0 && (
    <section class="sources shell" aria-labelledby="sources-title">
      <div class="section-heading section-heading--compact">
        <div>
          <p class="eyebrow">Transparencia</p>
          <h2 id="sources-title">Fuentes consultadas</h2>
        </div>
      </div>
      <ul class="source-list">
        {sources.map((source) => (
          <li>
            <span class={`source-state ${source.ok ? 'source-state--ok' : ''}`} aria-hidden="true"></span>
            <a href={source.url} target="_blank" rel="noopener noreferrer">{source.name}</a>
            <small>{source.ok ? `${source.scanned} publicaciones revisadas${source.kind === 'market-alert' ? ' · alerta no oficial' : ''}` : 'No disponible en la última comprobación'}</small>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
