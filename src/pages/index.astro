---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import OpportunityCard from '../components/OpportunityCard.astro';
import monitor from '../data/monitor.json';

const base = import.meta.env.BASE_URL;
const items = Array.isArray(monitor.items) ? monitor.items : [];
const sources = Array.isArray(monitor.sources) ? monitor.sources : [];
const marketItems = items.filter((item) => item.sourceKind === 'market-alert');
const publicItems = items.filter((item) => item.sourceKind !== 'market-alert');
const healthySources = sources.filter((source) => source.ok).length;
const checkedAt = monitor.checkedAt ? new Date(monitor.checkedAt) : null;
const checkedLabel = checkedAt
  ? checkedAt.toLocaleString('es-ES', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Europe/Madrid' })
  : 'Pendiente';
---

<Layout
  title="Vivienda Coruña — Cooperativas y promociones nuevas"
  description="Monitor de cooperativas, promociones nuevas y vivienda protegida en el área de A Coruña."
>
  <p class="tool-meta shell" aria-label="Estado de la última comprobación">
    <span class={`status-dot ${healthySources === sources.length && sources.length > 0 ? 'status-dot--ok' : ''}`} aria-hidden="true"></span>
    Actualizado {checkedLabel} · {healthySources}/{sources.length} fuentes
  </p>

  <div class="tool-layout shell">
    <section class="results" aria-labelledby="market-title">
      <div class="section-heading">
        <h2 id="market-title">Novedades <span>{marketItems.length}</span></h2>
        <p>Cooperativas y promociones detectadas en prensa local.</p>
      </div>

      {marketItems.length === 0 ? (
        <p class="empty-state">Sin novedades en esta comprobación.</p>
      ) : (
        <div class="opportunity-list">
          {marketItems.map((item) => <OpportunityCard {...item} />)}
        </div>
      )}

      {publicItems.length > 0 && (
        <details class="public-updates">
          <summary>Actualizaciones públicas <span>{publicItems.length}</span></summary>
          <div class="public-updates__content opportunity-list">
            {publicItems.map((item) => <OpportunityCard {...item} />)}
          </div>
        </details>
      )}
    </section>

    <aside class="coverage" aria-labelledby="coverage-title">
      <h2 id="coverage-title">Zona cubierta</h2>
      <img src={`${base}/coverage-map.svg`} alt="Mapa de A Coruña, Arteixo, Culleredo, Oleiros, Cambre, Sada, Bergondo, Carral y Abegondo" />
      <p>{monitor.area.length} municipios</p>
    </aside>
  </div>

  {sources.length > 0 && (
    <section class="sources shell" aria-labelledby="sources-title">
      <details>
        <summary id="sources-title">Fuentes <span>{sources.length}</span></summary>
        <ul class="source-list">
          {sources.map((source) => (
            <li>
              <span class={`source-state ${source.ok ? 'source-state--ok' : ''}`} aria-hidden="true"></span>
              <a href={source.url} target="_blank" rel="noopener noreferrer">{source.name}</a>
              <small>{source.ok ? `${source.scanned} revisadas` : 'No disponible'}</small>
            </li>
          ))}
        </ul>
      </details>
    </section>
  )}
</Layout>
